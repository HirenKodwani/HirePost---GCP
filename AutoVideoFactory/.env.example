AVF_ENVIRONMENT=development
AVF_DEBUG=true
AVF_HOST=127.0.0.1
AVF_PORT=8080
AVF_LOG_LEVEL=DEBUG

AVF_DATABASE_URL=sqlite+aiosqlite:///data/autovideofactory.db

AVF_BROWSER_TYPE=chromium
AVF_BROWSER_HEADLESS=false

AVF_LLM_PROVIDER=ollama
AVF_LLM_MODEL=qwen2.5:32b
AVF_OLLAMA_BASE_URL=http://localhost:11434

AVF_AUTH_ENABLED=false
AVF_AUTH_JWT_SECRET=change-me-in-production

AVF_SCHEDULER_ENABLED=false
AVF_ANALYTICS_ENABLED=true
AVF_LEARNING_ENABLED=true
