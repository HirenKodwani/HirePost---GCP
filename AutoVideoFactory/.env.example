AVF_ENVIRONMENT=development
AVF_DEBUG=true
AVF_HOST=127.0.0.1
AVF_PORT=8080
AVF_LOG_LEVEL=DEBUG

AVF_DATABASE_URL=sqlite+aiosqlite:///data/autovideofactory.db

AVF_BROWSER_TYPE=chromium
AVF_BROWSER_HEADLESS=false

AVF_LLM_PROVIDER=openai
AVF_OPENAI_BASE_URL=https://api.groq.com/openai/v1
AVF_OPENAI_DEFAULT_MODEL=llama-3.3-70b-versatile
AVF_OPENAI_API_KEY=gsk_yourPrimaryKey
AVF_OPENAI_API_KEY_BACKUP=gsk_yourBackupKey
AVF_OPENAI_API_KEY_TERTIARY=gsk_yourThirdKey

AVF_AUTH_ENABLED=false
AVF_AUTH_JWT_SECRET=change-me-in-production

AVF_SCHEDULER_ENABLED=false
AVF_ANALYTICS_ENABLED=true
AVF_LEARNING_ENABLED=true
